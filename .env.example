# ============================================================
# E-Commerce Kubernetes Project — Environment Variables
# Copy this to .env and fill in real values
# ============================================================

# ---- Global ----
ENVIRONMENT=development
LOG_LEVEL=debug
INTERNAL_GATEWAY_SECRET=change_me_to_a_secure_random_string
CORS_ORIGINS=http://localhost:3000,http://ecommerce.local

# ---- Auth Service ----
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change_me_auth

JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Product Service ----
PRODUCT_DB_HOST=product-db
PRODUCT_DB_PORT=5432
PRODUCT_DB_NAME=product_db
PRODUCT_DB_USER=product_user
PRODUCT_DB_PASSWORD=change_me_product

# ---- Order Service ----
ORDER_DB_HOST=order-db
ORDER_DB_PORT=5432
ORDER_DB_NAME=order_db
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=change_me_order

PRODUCT_SERVICE_URL=http://product-service:8002
CART_SERVICE_URL=http://cart-service:8003

# ---- Payment Service ----
PAYMENT_DB_HOST=order-db
PAYMENT_DB_PORT=5432
PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=change_me_payment

STRIPE_SECRET_KEY=sk_test_fake_key
STRIPE_WEBHOOK_SECRET=whsec_fake_secret

# ---- Cart Service ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CART_TTL_SECONDS=604800

# ---- API Gateway ----
GATEWAY_PORT=8080
AUTH_SERVICE_URL=http://auth-service:8001
RATE_LIMIT_PER_MINUTE=60
