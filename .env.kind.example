# ─────────────────────────────────────────────────────────────
# .env.kind.example — KIND local cluster secret template
# Copy this file to .env.kind and fill in your own values.
# .env.kind is gitignored and never committed.
# ─────────────────────────────────────────────────────────────

# ── Auth DB ──────────────────────────────────────────────────
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change_me_auth
AUTH_DB_NAME=auth_db

# ── Product DB ───────────────────────────────────────────────
PRODUCT_DB_USER=product_user
PRODUCT_DB_PASSWORD=change_me_product
PRODUCT_DB_NAME=product_db

# ── Order / Payment DB ───────────────────────────────────────
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=change_me_order
ORDER_DB_NAME=order_db

# ── Auth / Gateway ───────────────────────────────────────────
# Change this to a long, random string for local testing
JWT_SECRET_KEY=super_secret_dev_key_change_me

# ── Stripe (payment-service) ─────────────────────────────────
# Get your test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
